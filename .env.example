# 复制为 .env 后填写；应用启动时会加载项目根目录 .env
# cp .env.example .env

# —— Gitee OAuth（/auth/gitee/login）——
GITEE_OAUTH_CLIENT_ID=
GITEE_OAUTH_CLIENT_SECRET=
GITEE_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/auth/gitee/callback
# GITEE_OAUTH_SCOPES=user_info pull_requests projects hook

# —— 数据库（登录与 pr_review_reports 表）——
# DATABASE_URL=postgresql+psycopg://user:pass@127.0.0.1:5432/prreview

# —— 会话 ——
SESSION_SECRET=请换成长随机串

# —— 站点 URL（注册 WebHook 用）——
PUBLIC_BASE_URL=http://127.0.0.1:8000

# —— WebHook 与 LLM（自动审查）——
# GITEE_WEBHOOK_SECRET=
# DASHSCOPE_API_KEY=
